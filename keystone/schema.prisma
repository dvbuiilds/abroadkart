// This file is automatically generated by Keystone, do not modify it manually.
// Modify your Keystone config when you want to change this.

datasource postgresql {
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
  provider          = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String      @id @default(uuid()) @postgresql.Uuid
  clerkUserId String      @unique @default("")
  email       String      @unique @default("")
  name        String      @default("")
  role        String      @default("consultantAgent")
  tenant      Consultant? @relation("User_tenant", fields: [tenantId], references: [id])
  tenantId    String?     @map("tenant") @postgresql.Uuid
  isActive    Boolean     @default(true)
  createdAt   DateTime?   @default(now())
  updatedAt   DateTime?   @default(now()) @updatedAt

  @@index([role])
  @@index([tenantId])
}

model Consultant {
  id           String    @id @default(uuid()) @postgresql.Uuid
  name         String    @default("")
  slug         String    @unique @default("")
  contactEmail String    @default("")
  status       String    @default("active")
  users        User[]    @relation("User_tenant")
  createdAt    DateTime? @default(now())
  updatedAt    DateTime? @default(now()) @updatedAt

  @@index([status])
}
